                background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M2 10h3v10H2zm19-1c0-1.1-.9-2-2-2h-5.5l.92-4.65c.02-.13.02-.27-.03-.4l-.85-2.58L10.24 4.58c-.15.15-.24.36-.24.58V18c0 .55.45 1 1 1h6.31c.72 0 1.35-.47 1.55-1.16l2.77-9.24c.08-.25.11-.52.11-.79l-.02-.81z"/></svg>') !important;
                background-repeat: no-repeat !important;
                background-size: contain !important;
                transition: transform 0.1s ease !important;
            }
        `;
        document.head.appendChild(seyonUltimateMasterFix);
    }

    // run it instantly when the page loads
    applySeyonFix();

    // then re-run it every 3 seconds to keep it active on autopilot
    setInterval(applySeyonFix, 3000);
})();
