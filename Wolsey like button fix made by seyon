(function() {
    'use strict';

    // putting your code into a function so it can run on a loop
    function applySeyonFix() {
        // check if your style is already there so we don't spam the page
        if (document.getElementById('seyon-master-fix')) return;

        var seyonUltimateMasterFix = document.createElement('style');
        seyonUltimateMasterFix.id = 'seyon-master-fix';
        seyonUltimateMasterFix.innerHTML = `
            a.voted-yes i.icon-like-alt {
                visibility: hidden !important;
                opacity: 0 !important;
                width: 0 !important;
                height: 0 !important;
                margin: 0 !important;
                position: absolute !important;
            }
            a.voted-yes {
                position: relative !important;
                padding-left: 40px !important;
                display: inline-flex !important;
                align-items: center !important;
                justify-content: center !important;
                min-height: 20px !important;
                background: none !important;
            }
            a.voted-yes::before {
                content: "" !important;
                position: absolute !important;
                left: 15px !important;        
                top: 72% !important;        
                transform: translateY(-50%) !important;
                width: 18px !important;
